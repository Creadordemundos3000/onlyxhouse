rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    // For now, we hardcode specific admin emails
    // In a real app, you should use Custom Claims or a Users collection with roles
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.matches('.*@onlyxhouse[.]com') ||
        request.auth.token.email == 'sergymendoza@gmail.com' ||
        request.auth.token.email == 'admin@onlyxhouse.com'
      );
    }

    // Models collection
    match /models/{modelId} {
      allow read: if true; // Public can view models
      // Only admins can create/delete/update any model
      // Future: Allow models to update their own profile: if request.auth.uid == resource.data.userId
      allow create, update, delete: if isAdmin(); 
    }
    
    // Default rule: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
