rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // ⚠️ ADVERTENCIA: Estas reglas permiten que CUALQUIERA lea y escriba en tu base de datos.
      // Son solo para desarrollo. Para producción, debes restringirlas.
      allow read, write: if true;
    }
  }
}